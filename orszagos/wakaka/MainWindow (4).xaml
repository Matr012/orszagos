<Window x:Class="LolWPF_V2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LolWPF_V2"
        mc:Ignorable="d"
        Title="LOL hősök" Height="450" Width="800"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

       
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
            <TextBox x:Name="txtKereses" Width="200" Height="23" VerticalContentAlignment="Center" Margin="5"/>
            <Button x:Name="btnKereses" Content="Keresés" Width="100" Height="23" Margin="5" Click="btnKereses_Click"/>
            <Button x:Name="btnMentes" Content="Mentés" Width="100" Height="23" Margin="5" Click="btnMentes_Click"/>
        </StackPanel>

        
        <DataGrid Grid.Row="1" x:Name="dgHosok" 
                  ColumnWidth="*"
                  Margin="10,0,10,10"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>
    </Grid>
</Window>
