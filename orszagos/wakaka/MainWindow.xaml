<Window x:Class="celloveszetWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:celloveszetWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <DataGrid x:Name="dtgAdatok" ColumnWidth="*"/>
        <StackPanel Orientation="Vertical"  Grid.Column="1">
            <Label Content="Név:" HorizontalAlignment="Center" Margin="10"/>
            <Label Content="Lövés1:" HorizontalAlignment="Center" Margin="10"/>
            <Label Content="Lövés2:" HorizontalAlignment="Center" Margin="10"/>
            <Label Content="Lövés3:" HorizontalAlignment="Center" Margin="10"/>
            <Label Content="Lövés4:" HorizontalAlignment="Center" Margin="10"/>
        </StackPanel>
        <StackPanel Orientation="Vertical"  Grid.Column="2">
            <TextBox x:Name="tbxNev" Width="100" HorizontalAlignment="Left" Margin="0 14"/>
            <TextBox x:Name="tbxElso" Width="100" HorizontalAlignment="Left" Margin="0 14"/>
            <TextBox x:Name="tbxMasodik" Width="100" HorizontalAlignment="Left" Margin="0 14"/>
            <TextBox x:Name="tbxHarmadik" Width="100" HorizontalAlignment="Left" Margin="0 14"/>
            <TextBox x:Name="tbxNegyedik" Width="100" HorizontalAlignment="Left" Margin="0 14"/>

            <Button x:Name="btnHozzaad" Content="Hozzáad" HorizontalAlignment="Left" Click="btnHozzaad_Click"/>
            <Button x:Name="btnMentes" Content="Mentés" HorizontalAlignment="Left" Margin="0 20" Click="btnMentes_Click"/>
        </StackPanel>
    </Grid>
</Window>
